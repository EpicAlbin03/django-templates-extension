{
  "name": "django-template-language-server",
  "version": "0.0.0",
  "description": "A language server for Django templates in HTML files",
  "keywords": [
    "django",
    "formatter",
    "html",
    "language-server",
    "prettier",
    "syntax highlighting",
    "templates",
    "vscode"
  ],
  "license": "MIT",
  "bin": {
    "djangotemplateserver": "bin/server.js"
  },
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./bin/server.js": "./bin/server.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "prettier": "~3.3.3",
    "prettier-plugin-django-templates": "^0.1.2",
    "vscode-languageserver": "9.0.1",
    "vscode-languageserver-types": "3.17.5",
    "vscode-uri": "~3.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/sinon": "^7.5.2",
    "sinon": "^11.0.0",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">= 22.18.0"
  }
}
