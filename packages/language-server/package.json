{
  "name": "django-template-language-server",
  "version": "0.0.2",
  "description": "A language server for Django templates in HTML files",
  "keywords": [
    "django",
    "formatter",
    "html",
    "language-server",
    "prettier",
    "syntax highlighting",
    "templates",
    "vscode"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EpicAlbin03/django-templates-extension.git",
    "directory": "packages/language-server"
  },
  "bin": {
    "djangotemplateserver": "bin/server.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./bin/server.js": "./bin/server.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "prettier": "~3.3.3",
    "prettier-plugin-django-templates": "^0.2.0",
    "vscode-languageserver": "10.0.0",
    "vscode-languageserver-types": "3.18.0",
    "vscode-uri": "~3.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/sinon": "^7.5.2",
    "@typescript/native": "npm:typescript@^7.0.2",
    "sinon": "^22.0.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">= 22.18.0"
  }
}
