{
  "name": "django-vscode",
  "version": "0.5.0",
  "private": true,
  "description": "Django template language support for VS Code",
  "main": "dist/src/extension.js",
  "scripts": {
    "build": "tsc -p ./",
    "vscode:prepublish": "npm install && npm run build && npm prune --production",
    "watch": "tsc -w -p ./",
    "test": "node -e \"console.log('No extension tests configured')\""
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "engines": {
    "vscode": "^1.82.0"
  },
  "activationEvents": [
    "onLanguage:svelte",
    "onCommand:django.restartLanguageServer"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "restrictedConfigurations": [
        "django.language-server.runtime",
        "django.language-server.ls-path",
        "django.language-server.runtime-args"
      ],
      "description": "The extension requires workspace trust to execute workspace-specified language server settings."
    }
  },
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Django Templates",
      "properties": {
        "django.language-server.runtime": {
          "type": "string",
          "title": "Language Server Runtime",
          "description": "Path to the node executable used to spawn the language server."
        },
        "django.language-server.ls-path": {
          "type": "string",
          "title": "Language Server Path",
          "description": "Path to the language server entrypoint. Can be relative to the workspace root or absolute."
        },
        "django.language-server.runtime-args": {
          "type": "array",
          "title": "Language Server Runtime Args",
          "description": "Additional arguments to pass to the node executable when spawning the language server."
        },
        "django.language-server.port": {
          "type": "number",
          "title": "Language Server Port",
          "description": "Port to use for debugging the language server. -1 uses the default behavior.",
          "default": -1
        },
        "django.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace communication between VS Code and the language server."
        }
      }
    },
    "languages": [
      {
        "id": "svelte",
        "aliases": ["Django Templates", "django"],
        "extensions": [".svelte"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "svelte-start-tag",
        "configuration": "./language-configuration-start-tag.json"
      }
    ],
    "grammars": [
      {
        "language": "svelte",
        "scopeName": "source.svelte",
        "path": "./syntaxes/svelte.tmLanguage.json",
        "embeddedLanguages": {
          "text.html.basic": "html",
          "meta.tag.start.svelte": "svelte-start-tag",
          "punctuation.definition.tag.begin.svelte": "svelte",
          "source.css": "css",
          "source.js": "javascript",
          "source.ts": "typescript"
        },
        "unbalancedBracketScopes": [
          "keyword.operator.relational",
          "storage.type.function.arrow",
          "keyword.operator.bitwise.shift",
          "meta.brace.angle",
          "punctuation.definition.tag"
        ],
        "tokenTypes": {
          "punctuation.definition.template-expression": "other",
          "entity.name.type.instance.jsdoc": "other",
          "entity.name.function.tagged-template": "other",
          "meta.import string.quoted": "other",
          "variable.other.jsdoc": "other"
        }
      }
    ],
    "commands": [
      {
        "command": "django.restartLanguageServer",
        "title": "Django Templates: Restart Language Server"
      }
    ],
    "snippets": [
      {
        "language": "svelte",
        "path": "./snippets/svelte.json"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.67"
  },
  "dependencies": {
    "svelte-language-server": "workspace:*",
    "typescript": "^6.0.3",
    "vscode-languageclient": "^9.0.1"
  }
}
