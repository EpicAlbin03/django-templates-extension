{
  "name": "django-templates-ext",
  "displayName": "Django HTML Templates",
  "version": "0.0.0",
  "private": true,
  "description": "Django template language support for VS Code",
  "categories": [
    "Formatters",
    "Programming Languages"
  ],
  "keywords": [
    "django",
    "django templates",
    "formatter",
    "html",
    "language server",
    "prettier",
    "snippets",
    "syntax highlighting",
    "templates",
    "vscode"
  ],
  "homepage": "https://github.com/EpicAlbin03/django-templates-extension#readme",
  "bugs": {
    "url": "https://github.com/EpicAlbin03/django-templates-extension/issues"
  },
  "license": "MIT",
  "author": "Albin Carlsson <inquires@albincarlsson.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/EpicAlbin03/django-templates-extension.git"
  },
  "publisher": "EpicAlbin03",
  "type": "module",
  "main": "dist/extension.cjs",
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test --passWithNoTests",
    "check": "vp check",
    "vscode:prepublish": "vp install && vp run build && vp pm prune --prod"
  },
  "dependencies": {
    "django-template-language-server": "workspace:*",
    "vscode-languageclient": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/vscode": "^1.125.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "bumpp": "^11.1.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vite-plus": "catalog:",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.2.1"
  },
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Django Templates",
      "properties": {
        "django.language-server.runtime": {
          "type": "string",
          "title": "Language Server Runtime",
          "description": "Path to the node executable used to spawn the language server."
        },
        "django.language-server.ls-path": {
          "type": "string",
          "title": "Language Server Path",
          "description": "Path to the language server entrypoint. Can be relative to the workspace root or absolute."
        },
        "django.language-server.runtime-args": {
          "type": "array",
          "title": "Language Server Runtime Args",
          "description": "Additional arguments to pass to the node executable when spawning the language server."
        },
        "django.language-server.port": {
          "type": "number",
          "title": "Language Server Port",
          "description": "Port to use for debugging the language server. -1 uses the default behavior.",
          "default": -1
        },
        "django.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the language server."
        }
      }
    },
    "configurationDefaults": {
      "[html]": {
        "editor.links": false
      }
    },
    "grammars": [
      {
        "scopeName": "source.django.injection",
        "path": "./syntaxes/django-injection.tmLanguage.json",
        "injectTo": [
          "text.html",
          "text.html.basic",
          "text.html.derivative"
        ]
      }
    ],
    "commands": [
      {
        "command": "django.restartLanguageServer",
        "title": "Django Templates: Restart Language Server"
      }
    ],
    "snippets": [
      {
        "language": "html",
        "path": "./snippets/tags.json"
      },
      {
        "language": "html",
        "path": "./snippets/filters.json"
      }
    ]
  },
  "activationEvents": [
    "onCommand:django.restartLanguageServer",
    "onLanguage:html"
  ],
  "icon": "img/logo.png",
  "galleryBanner": {
    "color": "#092E20",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "restrictedConfigurations": [
        "django.language-server.runtime",
        "django.language-server.ls-path",
        "django.language-server.runtime-args"
      ],
      "description": "The extension requires workspace trust to execute workspace-specified language server settings."
    }
  }
}
