{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Django Template Injection",
  "scopeName": "source.django.injection",
  "injectionSelector": "L:text.html -comment -meta.embedded.verbatim.django, L:text.html.basic -comment -meta.embedded.verbatim.django, L:text.html.derivative -comment -meta.embedded.verbatim.django",
  "patterns": [
    { "include": "#wrapped-django-tags" },
    { "include": "#django-template-attributes" },
    { "include": "#django-comments" },
    { "include": "#django-verbatim-blocks" },
    { "include": "#django-template-tags" },
    { "include": "#django-template-variables" }
  ],
  "repository": {
    "wrapped-django-tags": {
      "patterns": [
        {
          "comment": "Django tags wrapped in /* */ for TS/JS compatibility",
          "name": "meta.embedded.django.wrapped",
          "match": "(/\\*)\\s*(\\{%[\\s\\S]*?%\\}|\\{\\{[\\s\\S]*?\\}\\}|\\{#[\\s\\S]*?#\\})\\s*(\\*/)",
          "captures": {
            "1": {
              "name": "punctuation.definition.comment.begin.django-wrapper"
            },
            "2": {
              "patterns": [
                { "include": "#django-comments" },
                { "include": "#django-verbatim-blocks" },
                { "include": "#django-template-tags" },
                { "include": "#django-template-variables" }
              ]
            },
            "3": { "name": "punctuation.definition.comment.end.django-wrapper" }
          }
        }
      ]
    },
    "django-template-tags": {
      "patterns": [
        {
          "name": "meta.embedded.django meta.tag.template.block.django",
          "begin": "(\\{%)(-)?\\s*",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.tag.begin.django entity.other.attribute-name.html"
            },
            "2": { "name": "keyword.operator.whitespace.django" }
          },
          "end": "\\s*(-)?(%\\})",
          "endCaptures": {
            "1": { "name": "keyword.operator.whitespace.django" },
            "2": {
              "name": "punctuation.definition.tag.end.django entity.other.attribute-name.html"
            }
          },
          "patterns": [
            { "include": "#django-for-tag-body" },
            { "include": "#django-tag-keywords" },
            { "include": "#django-filters" },
            { "include": "#django-strings" },
            { "include": "#django-numbers" },
            { "include": "#django-operators" },
            { "include": "#django-variables-inner" }
          ]
        }
      ]
    },
    "django-template-variables": {
      "patterns": [
        {
          "name": "meta.embedded.django meta.tag.template.variable.django",
          "begin": "(\\{\\{)(-)?\\s*",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.variable.begin.django entity.other.attribute-name.html"
            },
            "2": { "name": "keyword.operator.whitespace.django" }
          },
          "end": "\\s*(-)?(\\.\\}\\}|\\}\\})",
          "endCaptures": {
            "1": { "name": "keyword.operator.whitespace.django" },
            "2": {
              "name": "punctuation.definition.variable.end.django entity.other.attribute-name.html"
            }
          },
          "patterns": [
            { "include": "#django-filters" },
            { "include": "#django-strings" },
            { "include": "#django-numbers" },
            { "include": "#django-operators" },
            { "include": "#django-variables-inner" }
          ]
        }
      ]
    },
    "django-template-attributes": {
      "patterns": [
        {
          "name": "meta.attribute.template.django.html",
          "begin": "(?<![\\w:-])((?i:(?:data-)?(?:href|src|srcset)|xlink:href|action|formaction|poster))(?![\\w:-])\\s*(=)\\s*(\")",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.html" },
            "2": { "name": "punctuation.separator.key-value.html" },
            "3": { "name": "string.quoted.double.html punctuation.definition.string.begin.html" }
          },
          "contentName": "string.quoted.double.html",
          "end": "\"",
          "endCaptures": {
            "0": { "name": "string.quoted.double.html punctuation.definition.string.end.html" }
          },
          "patterns": [
            { "include": "#django-comments" },
            { "include": "#django-verbatim-blocks" },
            { "include": "#django-template-tags" },
            { "include": "#django-template-variables" }
          ]
        },
        {
          "name": "meta.attribute.template.django.html",
          "begin": "(?<![\\w:-])((?i:(?:data-)?(?:href|src|srcset)|xlink:href|action|formaction|poster))(?![\\w:-])\\s*(=)\\s*(')",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.html" },
            "2": { "name": "punctuation.separator.key-value.html" },
            "3": { "name": "string.quoted.single.html punctuation.definition.string.begin.html" }
          },
          "contentName": "string.quoted.single.html",
          "end": "'",
          "endCaptures": {
            "0": { "name": "string.quoted.single.html punctuation.definition.string.end.html" }
          },
          "patterns": [
            { "include": "#django-comments" },
            { "include": "#django-verbatim-blocks" },
            { "include": "#django-template-tags" },
            { "include": "#django-template-variables" }
          ]
        },
        {
          "name": "meta.attribute.template.django.html",
          "begin": "(?<![\\w:-])((?i:(?:data-)?(?:href|src|srcset)|xlink:href|action|formaction|poster))(?![\\w:-])\\s*(=)\\s*(?=[^\\s\"'=<>`/]|/(?!>))",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.html" },
            "2": { "name": "punctuation.separator.key-value.html" }
          },
          "contentName": "string.unquoted.html",
          "end": "(?=\\s|>)",
          "patterns": [
            { "include": "#django-comments" },
            { "include": "#django-verbatim-blocks" },
            { "include": "#django-template-tags" },
            { "include": "#django-template-variables" }
          ]
        }
      ]
    },
    "django-comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.django",
          "match": "(\\{#).*?(#\\})",
          "captures": {
            "1": { "name": "punctuation.definition.comment.begin.django" },
            "2": { "name": "punctuation.definition.comment.end.django" }
          }
        },
        {
          "name": "comment.block.django.multiline",
          "begin": "(\\{%)(-)?\\s*(comment)\\b(?:\\s+(?:\"[^\"]*\"|'[^']*'|[^%]*?))?\\s*(-)?(%\\})",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.comment.begin.django" },
            "2": { "name": "comment.block.django" },
            "3": { "name": "comment.block.django" },
            "4": { "name": "comment.block.django" },
            "5": { "name": "punctuation.definition.comment.begin.django" }
          },
          "end": "(\\{%)(-)?\\s*(endcomment)\\b\\s*(-)?(%\\})",
          "endCaptures": {
            "1": { "name": "punctuation.definition.comment.end.django" },
            "2": { "name": "comment.block.django" },
            "3": { "name": "comment.block.django" },
            "4": { "name": "comment.block.django" },
            "5": { "name": "punctuation.definition.comment.end.django" }
          }
        }
      ]
    },
    "django-verbatim-blocks": {
      "patterns": [
        {
          "name": "meta.tag.template.verbatim.django",
          "contentName": "meta.embedded.verbatim.django",
          "begin": "(\\{%)(-)?\\s*(verbatim)\\b(?:\\s+[^%]*?)?\\s*(-)?(%\\})",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.tag.begin.django entity.other.attribute-name.html"
            },
            "2": { "name": "keyword.operator.whitespace.django" },
            "3": { "name": "keyword.control.verbatim.django" },
            "4": { "name": "keyword.operator.whitespace.django" },
            "5": {
              "name": "punctuation.definition.tag.end.django entity.other.attribute-name.html"
            }
          },
          "end": "(\\{%)(-)?\\s*(endverbatim)\\b(?:\\s+[^%]*?)?\\s*(-)?(%\\})",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.tag.begin.django entity.other.attribute-name.html"
            },
            "2": { "name": "keyword.operator.whitespace.django" },
            "3": { "name": "keyword.control.verbatim.django" },
            "4": { "name": "keyword.operator.whitespace.django" },
            "5": {
              "name": "punctuation.definition.tag.end.django entity.other.attribute-name.html"
            }
          },
          "patterns": [{ "include": "text.html.basic" }]
        }
      ]
    },
    "django-for-tag-body": {
      "patterns": [
        {
          "name": "meta.tag.template.for.django",
          "begin": "\\G\\b(for)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.flow.django" }
          },
          "end": "(?=\\s*-?%\\})",
          "patterns": [
            {
              "name": "keyword.control.flow.django",
              "match": "\\bin\\b"
            },
            { "include": "#django-filters" },
            { "include": "#django-strings" },
            { "include": "#django-numbers" },
            { "include": "#django-operators" },
            { "include": "#django-variables-inner" }
          ]
        }
      ]
    },
    "django-tag-keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.django",
          "match": "\\G\\b(if|elif|else|endif|for|empty|endfor|while|endwhile|ifchanged|endifchanged|ifequal|endifequal|ifnotequal|endifnotequal)\\b"
        },
        {
          "name": "keyword.control.block.django",
          "match": "\\G\\b(block|endblock|extends|include|load|macro|endmacro|call|endcall|set|endset|partial|partialdef|endpartialdef)\\b"
        },
        {
          "name": "keyword.control.import.django",
          "match": "\\b(import|from|as)\\b"
        },
        {
          "name": "keyword.control.filter.django",
          "match": "\\G\\b(filter|endfilter)\\b"
        },
        {
          "name": "keyword.control.with.django",
          "match": "\\G\\b(with|endwith)\\b"
        },
        {
          "name": "keyword.control.autoescape.django",
          "match": "\\G\\b(autoescape|endautoescape)\\b"
        },
        {
          "name": "keyword.control.spaceless.django",
          "match": "\\G\\b(spaceless|endspaceless)\\b"
        },
        {
          "name": "keyword.control.verbatim.django",
          "match": "\\G\\b(verbatim|endverbatim)\\b"
        },
        {
          "name": "keyword.control.i18n.django",
          "match": "\\G\\b(trans|translate|blocktrans|endblocktrans|blocktranslate|endblocktranslate|plural|localize|endlocalize|localtime|endlocaltime|timezone|endtimezone|language|endlanguage|get_available_languages|get_current_language|get_current_language_bidi|get_language_info|get_language_info_list|get_current_timezone)\\b"
        },
        {
          "name": "keyword.control.url.django",
          "match": "\\G\\b(url|static|querystring|get_static_prefix|get_media_prefix|csrf_token)\\b"
        },
        {
          "name": "keyword.control.cache.django",
          "match": "\\G\\b(cache|endcache)\\b"
        },
        {
          "name": "keyword.control.cycle.django",
          "match": "\\G\\b(cycle|firstof)\\b"
        },
        {
          "name": "keyword.control.debug.django",
          "match": "\\G\\b(debug|now|regroup|resetcycle|templatetag|widthratio|lorem)\\b"
        },
        {
          "comment": "Additional formatter-supported tags from prettier-plugin-django-templates",
          "name": "keyword.control.tag.django",
          "match": "\\G\\b(thumbnail|endthumbnail|component|endcomponent|component_block|endcomponent_block|fill|endfill|slot|endslot|provide|endprovide|html_attrs|component_css_dependencies|component_js_dependencies|compress|endcompress|addtoblock|endaddtoblock|with_data|endwith_data|render_block|add_data|flag|endflag|switch|endswitch|sample|endsample|wafflejs|recursetree|endrecursetree|drilldown_tree_for_node|full_tree_for_model|placeholder|endplaceholder|static_placeholder|endstatic_placeholder|render_model_block|endrender_model_block|render_model_add_block|endrender_model_add_block|render_plugin_block|endrender_plugin_block|cms_admin_url|page_attribute|page_url|page_id_url|page_language_url|render_model|render_model_icon|render_model_add|render_placeholder|render_uncached_placeholder|render_plugin|show_placeholder|static_alias|cms_toolbar|element|endelement|crispy_addon|endcrispy_addon|crispy|crispy_field|csp_nonce_attr|comment|endcomment)\\b"
        },
        {
          "name": "keyword.operator.logical.django",
          "match": "\\b(and|or|not|in|is)\\b"
        },
        {
          "name": "constant.language.django",
          "match": "\\b(True|False|None)\\b"
        },
        {
          "comment": "Fallback for custom or unknown Django template tag names at the start of a tag block",
          "name": "keyword.control.tag.django",
          "match": "\\G\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "django-filters": {
      "patterns": [
        {
          "match": "(\\|)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.operator.filter.django" },
            "2": { "name": "support.function.filter.django" }
          }
        }
      ]
    },
    "django-strings": {
      "patterns": [
        {
          "name": "string.quoted.double.django",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.django",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.django",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.django",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "django-numbers": {
      "patterns": [
        {
          "name": "constant.numeric.django",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "django-operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.django",
          "match": "==|!=|<>|<=?|>=?"
        },
        {
          "name": "keyword.operator.assignment.django",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.django",
          "match": "\\*\\*|//|\\+|-|\\*|/|%"
        },
        {
          "name": "punctuation.separator.django",
          "match": "[:,]"
        }
      ]
    },
    "django-variables-inner": {
      "patterns": [
        {
          "comment": "Dotted variable chains use TypeScript-like object/property scopes for theme compatibility.",
          "name": "meta.variable.dotted.django",
          "begin": "(?<![a-zA-Z0-9_.])([a-zA-Z_][a-zA-Z0-9_]*)(?=\\.[a-zA-Z_])",
          "beginCaptures": {
            "1": { "name": "variable.other.object.django" }
          },
          "end": "(?!\\.[a-zA-Z_])",
          "patterns": [
            {
              "comment": "Middle segments in a dotted variable chain, like `email` in `form.email.errors`.",
              "match": "(\\.)([a-zA-Z_][a-zA-Z0-9_]*)(?=\\.[a-zA-Z_])",
              "captures": {
                "1": { "name": "punctuation.accessor.django" },
                "2": { "name": "variable.other.object.property.django" }
              }
            },
            {
              "comment": "Final segments in a dotted variable chain, like `errors` in `form.email.errors`.",
              "match": "(\\.)([a-zA-Z_][a-zA-Z0-9_]*)(?!\\.[a-zA-Z_])",
              "captures": {
                "1": { "name": "punctuation.accessor.django" },
                "2": { "name": "variable.other.property.django" }
              }
            }
          ]
        },
        {
          "name": "variable.other.django",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "punctuation.accessor.django",
          "match": "\\."
        }
      ]
    }
  }
}
