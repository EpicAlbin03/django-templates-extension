    "description": "{% regroup %}",
    "prefix": "regroup_example",
    "body": [
      "{% regroup ${1:object_list} by ${2:category} as ${2:category}_list %}",
      "<ul>",
      "    {% for ${2:category}, ${3:obj}_list in ${2:category}_list %}",
      "        <li>{{ ${2:category} }}",
      "        <ul>",
      "            {% for ${3:obj} in ${3:obj}_list %}",
      "                <li>{{ ${3:obj} }}</li>",
      "            {% endfor %}",
      "        </ul>",
      "        </li>",
