{
  "name": "prettier-plugin-django",
  "version": "0.1.0",
  "description": "Django template plugin for Prettier",
  "main": "plugin.js",
  "files": [
    "plugin.js",
    "plugin.js.map",
    "browser.js",
    "index.d.ts"
  ],
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./plugin.js"
    },
    "./browser": "./browser.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rollup -c",
    "check": "tsc --noEmit",
    "check:watch": "tsc --noEmit --watch",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "ava",
    "prepare": "pnpm build",
    "prepublishOnly": "pnpm test",
    "changeset:version": "changeset version && git add --all",
    "changeset:publish": "changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EpicAlbin03/prettier-plugin-django.git"
  },
  "keywords": [
    "prettier",
    "django"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/EpicAlbin03/prettier-plugin-django/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "homepage": "https://github.com/EpicAlbin03/prettier-plugin-django#readme",
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.31.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24",
    "ava": "8.0.1",
    "prettier": "^3.8.0",
    "rollup": "4.61.1",
    "ts-node": "^10.9.2",
    "tsimp": "^2.0.12",
    "tslib": "^2.8.1",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@11.5.2",
  "peerDependencies": {
    "prettier": "^3.0.0"
  }
}
